{
  "expo": {
    "name": "QR Contact Card",
    "slug": "qr-contact-card",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes containing contact information.",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to save your QR code image.",
        "NSPhotoLibraryAddUsageDescription": "Needed to save your QR code to the photo library.",
        "NSContactsUsageDescription": "Contacts access is needed to import scanned vCard contacts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CONTACTS"
      ],
      "package": "com.qrcontactcard.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      "expo-camera",
      "expo-media-library",
      [
        "expo-brightness",
        {
          "microphonePermission": false
        }
      ]
    ]
  }
}
